<?xml version="1.0" encoding="utf-8" ?>
<!--
    Defines which directories the FileProvider can share with other apps.
    Required to hand the downloaded APK to the Android Package Installer
    on Android 7.0 (API 24) and above.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">

	<!-- /data/data/com.finderlite/cache  →  exposed for APK install -->
	<cache-path name="finder_cache" path="." />

	<!-- /data/data/com.finderlite/files -->
	<files-path name="finder_files" path="." />

	<!-- App-private external cache directory -->
	<external-cache-path name="finder_ext_cache" path="." />

</paths>