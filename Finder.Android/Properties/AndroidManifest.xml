<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools"
          package="com.finderlite"
          android:versionCode="1"
          android:versionName="1.0">

	<uses-sdk android:minSdkVersion="21"
              android:targetSdkVersion="33" />

	<!-- ── Permissions ── -->
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
	<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
	<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
	<uses-permission android:name="android.permission.WAKE_LOCK" />

	<!-- Required on Android 13 (API 33) to post notifications -->
	<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

	<application android:label="Finder Lite"
                 android:icon="@mipmap/icon"
                 android:theme="@style/MainTheme"
                 android:allowBackup="true">

		<!--
            Merge foregroundServiceType="location" into the service entry
            auto-generated by Xamarin from the [Service] attribute.
            The android:name must match the Name= value in the C# attribute.
        -->
		<service android:name="com.finderlite.BackgroundLocationService"
                 android:foregroundServiceType="location"
                 android:enabled="true"
                 android:exported="false"
                 tools:node="merge" />

	</application>
</manifest>