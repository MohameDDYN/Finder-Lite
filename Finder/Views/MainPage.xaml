<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Finder.Views.MainPage"
             Title="Finder Lite"
             BackgroundColor="{StaticResource BackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20,16" Spacing="0">

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  Hero Banner                                                -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Frame Style="{StaticResource CardStyle}" Padding="24,20">
                <StackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="📡" FontSize="52" HorizontalOptions="Center" />
                    <Label Text="Finder Lite"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryColor}"
                           HorizontalOptions="Center" />
                    <Label Text="On-Demand GPS via Telegram"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondaryColor}"
                           HorizontalOptions="Center" />
                </StackLayout>
            </Frame>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  Status Card                                                -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Frame Style="{StaticResource CardStyle}">
                <StackLayout Spacing="10">
                    <Label Text="STATUS" Style="{StaticResource SectionLabelStyle}" />

                    <StackLayout Orientation="Horizontal" Spacing="10">
                        <BoxView WidthRequest="14" HeightRequest="14"
                                 CornerRadius="7"
                                 VerticalOptions="Center"
                                 Color="{Binding StatusDotColor}" />
                        <Label Text="{Binding StatusText}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimaryColor}"
                               VerticalOptions="Center" />
                    </StackLayout>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource PrimaryColor}"
                                       HeightRequest="28" />
                </StackLayout>
            </Frame>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  Telegram Settings Card                                     -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Frame Style="{StaticResource CardStyle}">
                <StackLayout Spacing="8">
                    <Label Text="TELEGRAM SETTINGS"
                           Style="{StaticResource SectionLabelStyle}" />

                    <Label Text="Bot Token"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondaryColor}" />
                    <Frame Padding="12,0" CornerRadius="10"
                           BorderColor="{StaticResource TextLightColor}"
                           HasShadow="False"
                           BackgroundColor="{StaticResource BackgroundColor}">
                        <Entry Text="{Binding BotToken, Mode=TwoWay}"
                               Placeholder="123456789:ABCDef…"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimaryColor}"
                               PlaceholderColor="{StaticResource TextLightColor}"
                               BackgroundColor="Transparent" />
                    </Frame>

                    <Label Text="Chat ID"
                           FontSize="12"
                           Margin="0,6,0,0"
                           TextColor="{StaticResource TextSecondaryColor}" />
                    <Frame Padding="12,0" CornerRadius="10"
                           BorderColor="{StaticResource TextLightColor}"
                           HasShadow="False"
                           BackgroundColor="{StaticResource BackgroundColor}">
                        <Entry Text="{Binding ChatId, Mode=TwoWay}"
                               Placeholder="-100123456789"
                               Keyboard="Numeric"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimaryColor}"
                               PlaceholderColor="{StaticResource TextLightColor}"
                               BackgroundColor="Transparent" />
                    </Frame>

                    <Button Text="💾  Save Settings"
                            Command="{Binding SaveSettingsCommand}"
                            BackgroundColor="{StaticResource TextSecondaryColor}"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="46"
                            FontSize="14"
                            Margin="0,8,0,0" />
                </StackLayout>
            </Frame>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  Service Control Card                                       -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Frame Style="{StaticResource CardStyle}">
                <StackLayout Spacing="10">
                    <Label Text="CONTROL" Style="{StaticResource SectionLabelStyle}" />

                    <Button Text="▶  Start Service"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding StartServiceCommand}"
                            IsVisible="{Binding IsServiceRunning,
                                        Converter={StaticResource InverseBool}}" />

                    <Button Text="■  Stop Service"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding StopServiceCommand}"
                            IsVisible="{Binding IsServiceRunning}" />
                </StackLayout>
            </Frame>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  Commands Reference Card                                    -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Frame Style="{StaticResource CardStyle}">
                <StackLayout Spacing="10">
                    <Label Text="TELEGRAM COMMANDS"
                           Style="{StaticResource SectionLabelStyle}" />

                    <Grid ColumnSpacing="14" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="/location"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}" />
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="Get GPS coordinates + Maps link"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}"
                               VerticalOptions="Center" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="/status"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="Service, GPS, battery state"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}"
                               VerticalOptions="Center" />

                        <Label Grid.Row="2" Grid.Column="0"
                               Text="/version"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="Show installed app version"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}"
                               VerticalOptions="Center" />

                        <Label Grid.Row="3" Grid.Column="0"
                               Text="/update"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}" />
                        <Label Grid.Row="3" Grid.Column="1"
                               Text="Self-update from APK URL"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}"
                               VerticalOptions="Center" />

                        <Label Grid.Row="4" Grid.Column="0"
                               Text="/help"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}" />
                        <Label Grid.Row="4" Grid.Column="1"
                               Text="Show all available commands"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}"
                               VerticalOptions="Center" />

                        <Label Grid.Row="5" Grid.Column="0"
                               Text="/start"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}" />
                        <Label Grid.Row="5" Grid.Column="1"
                               Text="Welcome message and help"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondaryColor}"
                               VerticalOptions="Center" />
                    </Grid>
                </StackLayout>
            </Frame>

            <Label Text="Finder Lite · GPS on demand, nothing more."
                   FontSize="11"
                   TextColor="{StaticResource TextLightColor}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,4,0,24" />

        </StackLayout>
    </ScrollView>
</ContentPage>