<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:Finder.Converters"
             x:Class="Finder.App">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ── Converter ── -->
            <converters:InverseBoolConverter x:Key="InverseBool" />

            <!-- ── Palette ── -->
            <Color x:Key="PrimaryColor">#1565C0</Color>
            <Color x:Key="PrimaryDarkColor">#003c8f</Color>
            <Color x:Key="AccentColor">#4CAF50</Color>
            <Color x:Key="DangerColor">#E53935</Color>
            <Color x:Key="BackgroundColor">#EEF2F7</Color>
            <Color x:Key="CardColor">#FFFFFF</Color>
            <Color x:Key="TextPrimaryColor">#1A1A2E</Color>
            <Color x:Key="TextSecondaryColor">#6B7280</Color>
            <Color x:Key="TextLightColor">#C0C8D8</Color>

            <!-- ── Card Frame ── -->
            <Style x:Key="CardStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
                <Setter Property="CornerRadius"    Value="16" />
                <Setter Property="HasShadow"       Value="True" />
                <Setter Property="Padding"         Value="18" />
                <Setter Property="Margin"          Value="0,0,0,14" />
                <Setter Property="BorderColor"     Value="Transparent" />
            </Style>

            <!-- ── Section Label ── -->
            <Style x:Key="SectionLabelStyle" TargetType="Label">
                <Setter Property="TextColor"     Value="{StaticResource TextSecondaryColor}" />
                <Setter Property="FontSize"      Value="11" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin"        Value="0,0,0,8" />
            </Style>

            <!-- ── Primary Button ── -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="TextColor"       Value="White" />
                <Setter Property="CornerRadius"    Value="12" />
                <Setter Property="HeightRequest"   Value="54" />
                <Setter Property="FontSize"        Value="16" />
                <Setter Property="FontAttributes"  Value="Bold" />
            </Style>

            <!-- ── Danger Button ── -->
            <Style x:Key="DangerButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource DangerColor}" />
                <Setter Property="TextColor"       Value="White" />
                <Setter Property="CornerRadius"    Value="12" />
                <Setter Property="HeightRequest"   Value="54" />
                <Setter Property="FontSize"        Value="16" />
                <Setter Property="FontAttributes"  Value="Bold" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>